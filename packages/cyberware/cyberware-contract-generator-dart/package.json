  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cyberware-contract-generator-dart": "./dist/bin.js"
  },
  "exports": {
    "./package.json": "./package.json",
